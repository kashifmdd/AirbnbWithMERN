<% layout('layouts/boilerplate') %>
<div class="row mt-4">
    <div class="col-8 offset-3">
        <h3><%= listing.title %></h3>
        <img src="<%= listing.image %>" alt="listing_image" class="card col-6 show-card listing-card">
        <div class="card-body">
            <p class="card-text"><%= listing.description %></p>
            <p class="card-text"><strong>Price:</strong> &#8377; <%= listing.price.toLocaleString("en-IN") %></p>
        </div>
        <div class="row">
            <div class="col-md-4">
                <p class="card-text"><strong>Location:</strong> <%= listing.location %></p>
            </div>
            <div class="col-md-8">
                <p class="card-text"><strong>Country:</strong> <%= listing.country %></p>
            </div>
        </div>
    </div>
    <div class="btns mt-3">
    <a href="/listings/<%= listing._id %>/edit" class="btn btn-blue col-1 offset-3" >Edit</a>
    <br><br>
    <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
        <button class="del-btn offset-3">Delete Listing</button>
    </form>
    </div>

    <div class="col-8 offset-3 mb-3">
        <hr>
        <h4>Leave a Review</h4>
        <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
            <div class="mb-3 mt-3">
                <label for="rating" class="form-label">Rating</label>
                <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range">
            </div>
            <div class="mb-3 mt-3">
                <label for="comment" class="form-label">Comments</label>
                <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control" required></textarea>
                <div class="invalid-feedback">Please add some review</div>
            </div>
                <button class="btn btn-outline-dark mb-3">Submit</button>
        </form>
        <h4>All Reviews</h4>
        <% listing.reviews.forEach(review => { %>
            <div class="card mb-3 mt-3">
                <div class="card-body m-2"  >
                    <h5 class="card-title">Rating: <%= review.rating %> star</h5>
                    <p class="card-text  m-2"><%= review.comment %></p>
                </div>
                <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class=" m-2">
                    <button class="btn btn-sm btn-dark">Delete</button>
                </form>
            </div>
        <% }); %>
    </div>
</div>